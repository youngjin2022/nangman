NODE_ENV=development
PORT=4000

# ===== Database =====
# Railway: PostgreSQL 플러그인 추가 시 DATABASE_URL이 자동 주입됨
# 로컬: docker-compose 또는 로컬 Postgres 사용
DATABASE_URL=postgresql://nangman:nangman@localhost:5432/nangman?schema=public

# ===== Redis (선택) =====
# Railway: Redis 플러그인 추가 시 REDIS_URL 자동 주입
# REDIS_URL=redis://localhost:6379

# ===== 인증 =====
JWT_SECRET=replace-me-in-production

# ===== 결제 (PortOne / 토스페이먼츠 - 추후) =====
PORTONE_API_KEY=
PORTONE_API_SECRET=

# ===== 프린트 에이전트 토큰 (5단계) =====
PRINT_AGENT_TOKEN=

# ===== 매장 (단일 매장 실행 시 업로드 키 prefix) =====
# DEFAULT_STORE_ID=store-001

# ===== 메뉴 이미지 업로드 (S3 호환 PutObject → DB에는 공개 URL만 저장) =====
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=   # 또는 S3_BUCKET_NAME=nangman-menu-images
#
# --- Amazon S3만 쓸 때 ---
# AWS_REGION=ap-northeast-2
# 선택: CloudFront 등 퍼블릭 베이스
# S3_PUBLIC_BASE_URL=https://cdn.example.com
#
# --- Cloudflare R2 (AWS 대체) ---
# R2 대시보드 → R2 → API 로 엔드포인트·API 토큰(액세스 키 ID/시크릿) 발급
# R2_ENDPOINT=https://39ccf8bbd4e4dee4b7a93e9d0035fd69.r2.cloudflarestorage.com
# R2 사용 시 손님/브라우저에서 열리는 공개 베이스 필수 (커스텀 도메인 또는 R2 public URL)
# S3_PUBLIC_BASE_URL=https://img.example.com
#
# --- 기타 S3 호환 (MinIO 등) ---
# S3_ENDPOINT=http://localhost:9000
# S3_PUBLIC_BASE_URL=... (커스텀 엔드포인트일 때 필수)

