# 백엔드 API 엔드포인트
NEXT_PUBLIC_API_URL=http://localhost:4000

# (선택) Socket.IO 서버 - customer-web은 현재 미사용, 추후 주문 상태 실시간 갱신용
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# 배포 시 (Vercel) 예시:
# NEXT_PUBLIC_API_URL=https://nangman-api.up.railway.app
# NEXT_PUBLIC_SOCKET_URL=https://nangman-api.up.railway.app
