{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm install -g pnpm@9.6.0 && cd ../.. && pnpm@9.6.0 install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm turbo run build --filter=customer-web",
  "outputDirectory": ".next",
  "ignoreCommand": "cd ../.. && npx turbo-ignore customer-web"
}