// ============================================================
// 낭만포차 — Prisma 스키마
// 2단계 ERD를 그대로 옮김. 변경 시 마이그레이션 생성:
//   pnpm --filter api prisma migrate dev --name <설명>
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =================== Enums ===================

enum StaffRole {
  OWNER
  MANAGER
  SERVER
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  SERVED
  COMPLETED
  CANCELLED
}

enum OrderItemStatus {
  ORDERED
  PREPARING
  SERVED
  CANCELLED
}

enum OrderType {
  CUSTOMER_MOBILE
  POS
}

enum PaymentMethod {
  CARD
  CASH
  KAKAO
  NAVER
  TOSS
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIAL_REFUNDED
}

enum PrinterType {
  KITCHEN
  HALL
}

enum PrintJobStatus {
  QUEUED
  PRINTED
  FAILED
}

// =================== Models ===================

model Store {
  id             String   @id @default(cuid())
  name           String
  businessNumber String?  @map("business_number")
  phone          String?
  address        String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  staff      Staff[]
  tables     RestaurantTable[]
  categories MenuCategory[]
  menus      Menu[]
  orders     Order[]
  dailySales DailySales[]

  @@map("stores")
}

model Staff {
  id           String    @id @default(cuid())
  storeId      String    @map("store_id")
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  role         StaffRole @default(SERVER)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")

  store         Store        @relation(fields: [storeId], references: [id])
  createdOrders Order[]      @relation("OrderCreatedBy")
  closedSales   DailySales[] @relation("DailySalesClosedBy")

  @@index([storeId])
  @@map("staff")
}

model RestaurantTable {
  id          String      @id @default(cuid())
  storeId     String      @map("store_id")
  tableNumber String      @map("table_number")
  name        String
  qrToken     String      @unique @map("qr_token")
  capacity    Int         @default(4)
  status      TableStatus @default(AVAILABLE)
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")

  store  Store   @relation(fields: [storeId], references: [id])
  orders Order[]

  @@index([storeId])
  @@index([qrToken])
  @@map("restaurant_tables")
}

model MenuCategory {
  id           String   @id @default(cuid())
  storeId      String   @map("store_id")
  name         String
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  store Store  @relation(fields: [storeId], references: [id])
  menus Menu[]

  @@index([storeId])
  @@map("menu_categories")
}

model Menu {
  id           String   @id @default(cuid())
  storeId      String   @map("store_id")
  categoryId   String   @map("category_id")
  name         String
  description  String?
  price        Int
  imageUrl     String?  @map("image_url")
  isSoldOut    Boolean  @default(false) @map("is_sold_out")
  isActive     Boolean  @default(true) @map("is_active")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  store        Store             @relation(fields: [storeId], references: [id])
  category     MenuCategory      @relation(fields: [categoryId], references: [id])
  optionGroups MenuOptionGroup[]
  orderItems   OrderItem[]

  @@index([storeId, categoryId])
  @@map("menus")
}

model MenuOptionGroup {
  id           String  @id @default(cuid())
  menuId       String  @map("menu_id")
  name         String
  isRequired   Boolean @default(false) @map("is_required")
  minSelect    Int     @default(0) @map("min_select")
  maxSelect    Int     @default(1) @map("max_select")
  displayOrder Int     @default(0) @map("display_order")

  menu  Menu             @relation(fields: [menuId], references: [id], onDelete: Cascade)
  items MenuOptionItem[]

  @@index([menuId])
  @@map("menu_option_groups")
}

model MenuOptionItem {
  id              String  @id @default(cuid())
  optionGroupId   String  @map("option_group_id")
  name            String
  additionalPrice Int     @default(0) @map("additional_price")
  isDefault       Boolean @default(false) @map("is_default")
  displayOrder    Int     @default(0) @map("display_order")

  group      MenuOptionGroup   @relation(fields: [optionGroupId], references: [id], onDelete: Cascade)
  selectedIn OrderItemOption[]

  @@index([optionGroupId])
  @@map("menu_option_items")
}

model Order {
  id               String      @id @default(cuid())
  storeId          String      @map("store_id")
  tableId          String      @map("table_id")
  orderNumber      String      @unique @map("order_number")
  status           OrderStatus @default(PENDING)
  orderType        OrderType   @default(CUSTOMER_MOBILE) @map("order_type")
  subtotal         Int         @default(0)
  discountAmount   Int         @default(0) @map("discount_amount")
  totalAmount      Int         @default(0) @map("total_amount")
  guestCount       Int?        @map("guest_count")
  memo             String?
  createdByStaffId String?     @map("created_by_staff_id")
  requestedAt      DateTime    @default(now()) @map("requested_at")
  confirmedAt      DateTime?   @map("confirmed_at")
  completedAt      DateTime?   @map("completed_at")
  cancelledAt      DateTime?   @map("cancelled_at")
  cancelReason     String?     @map("cancel_reason")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  store          Store           @relation(fields: [storeId], references: [id])
  table          RestaurantTable @relation(fields: [tableId], references: [id])
  createdByStaff Staff?          @relation("OrderCreatedBy", fields: [createdByStaffId], references: [id])
  items          OrderItem[]
  payments       Payment[]
  printJobs      PrintJob[]

  @@index([storeId, status, requestedAt])
  @@index([tableId, status])
  @@map("orders")
}

model OrderItem {
  // 핵심: 메뉴명·단가는 스냅샷 - 메뉴 수정/삭제에도 과거 주문 무결성 보장
  id               String          @id @default(cuid())
  orderId          String          @map("order_id")
  menuId           String          @map("menu_id")
  menuNameSnapshot String          @map("menu_name_snapshot")
  unitPrice        Int             @map("unit_price")
  quantity         Int             @default(1)
  subtotal         Int
  status           OrderItemStatus @default(ORDERED)
  memo             String?
  createdAt        DateTime        @default(now()) @map("created_at")

  order           Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menu            Menu              @relation(fields: [menuId], references: [id])
  selectedOptions OrderItemOption[]

  @@index([orderId])
  @@map("order_items")
}

model OrderItemOption {
  id                      String   @id @default(cuid())
  orderItemId             String   @map("order_item_id")
  optionItemId            String   @map("option_item_id")
  optionNameSnapshot      String   @map("option_name_snapshot")
  additionalPriceSnapshot Int      @map("additional_price_snapshot")
  createdAt               DateTime @default(now()) @map("created_at")

  orderItem  OrderItem      @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  optionItem MenuOptionItem @relation(fields: [optionItemId], references: [id])

  @@index([orderItemId])
  @@map("order_item_options")
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String        @map("order_id")
  paymentMethod   PaymentMethod @map("payment_method")
  amount          Int
  status          PaymentStatus @default(PENDING)
  pgProvider      String?       @map("pg_provider")
  pgTransactionId String?       @unique @map("pg_transaction_id")
  approvedAt      DateTime?     @map("approved_at")
  cancelledAt     DateTime?     @map("cancelled_at")
  refundAmount    Int           @default(0) @map("refund_amount")
  receiptUrl      String?       @map("receipt_url")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("payments")
}

model DailySales {
  id              String    @id @default(cuid())
  storeId         String    @map("store_id")
  salesDate       DateTime  @db.Date @map("sales_date")
  totalOrders     Int       @default(0) @map("total_orders")
  grossSales     Int       @default(0) @map("gross_sales")
  discountTotal   Int       @default(0) @map("discount_total")
  netSales        Int       @default(0) @map("net_sales")
  cashSales       Int       @default(0) @map("cash_sales")
  cardSales       Int       @default(0) @map("card_sales")
  mobileSales     Int       @default(0) @map("mobile_sales")
  refundAmount    Int       @default(0) @map("refund_amount")
  closedAt        DateTime? @map("closed_at")
  closedByStaffId String?   @map("closed_by_staff_id")
  createdAt       DateTime  @default(now()) @map("created_at")

  store         Store  @relation(fields: [storeId], references: [id])
  closedByStaff Staff? @relation("DailySalesClosedBy", fields: [closedByStaffId], references: [id])

  @@unique([storeId, salesDate])
  @@map("daily_sales")
}

model PrintJob {
  id           String         @id @default(cuid())
  orderId      String         @map("order_id")
  printerType  PrinterType    @map("printer_type")
  status       PrintJobStatus @default(QUEUED)
  payload      Json
  attempts     Int            @default(0)
  printedAt    DateTime?      @map("printed_at")
  errorMessage String?        @map("error_message")
  createdAt    DateTime       @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])

  @@index([status])
  @@index([orderId])
  @@map("print_jobs")
}
